# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-production-use-50-random-chars
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=retrievia
POSTGRES_USER=retrievia
POSTGRES_PASSWORD=retrievia_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/1

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_secret
QDRANT_COLLECTION_NAME=retrievia_chunks

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Encryption (for storing OAuth tokens) ────────────────────────────────────
FIELD_ENCRYPTION_KEY=change-me-generate-with-cryptography-fernet

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/integrations/slack/oauth/callback/

# ─── Google (Drive + Gmail) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/oauth/callback/

# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/integrations/notion/oauth/callback/

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ─── AWS (production only) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ─── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=
